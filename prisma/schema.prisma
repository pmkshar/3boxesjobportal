generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── User & Auth ──────────────────────────────────────────────

enum UserRole {
  JOB_SEEKER
  CORPORATE
  RECRUITER
  ADMIN
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  password      String
  role          UserRole @default(JOB_SEEKER)
  avatar        String?
  phone         String?
  location      String?
  bio           String?
  isActive      Boolean  @default(true)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  jobSeekerProfile    JobSeekerProfile?
  corporateProfile    CorporateProfile?
  recruiterProfile    RecruiterProfile?
  resumes             Resume[]
  applications        Application[]
  interviews          Interview[]
  trainingEnrollments TrainingEnrollment[]
  aiInterviewSessions AiInterviewSession[]
  analyticsEvents     AnalyticsEvent[]
  notifications       Notification[]
  savedJobs           SavedJob[]
  skillAssessments    SkillAssessment[]
}

// ─── Job Seeker Profile ──────────────────────────────────────

model JobSeekerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  headline        String?
  experienceYears Int      @default(0)
  currentRole     String?
  currentCompany  String?
  education       String?
  expectedSalary  String?
  jobType         String?  // full-time, part-time, contract, remote
  availability    String?  // immediate, 2-weeks, 1-month
  linkedInUrl     String?
  portfolioUrl    String?
  githubUrl       String?
  skills          String?  // comma-separated skills
  aiSkillScore    Float    @default(0)
  profileComplete Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Corporate Profile ──────────────────────────────────────

model CorporateProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  companyName     String
  companyLogo     String?
  industry        String?
  companySize     String?  // 1-10, 11-50, 51-200, 201-500, 501-1000, 1000+
  website         String?
  description     String?
  location        String?
  foundedYear     Int?
  linkedInUrl     String?
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs Job[]
}

// ─── Recruiter Profile ──────────────────────────────────────

model RecruiterProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  corporateId     String?
  specialization  String?  // IT, Finance, Healthcare, etc.
  yearsExperience Int      @default(0)
  certifications  String?  // comma-separated
  placementCount  Int      @default(0)
  rating          Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Jobs ──────────────────────────────────────────────────────

enum JobStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  ARCHIVED
}

model Job {
  id              String    @id @default(cuid())
  corporateId     String
  title           String
  description     String
  requirements    String?
  responsibilities String?
  salaryMin       Int?
  salaryMax       Int?
  salaryCurrency  String    @default("INR")
  jobType         String    @default("full-time") // full-time, part-time, contract, remote, hybrid
  experienceMin   Int?
  experienceMax   Int?
  location        String?
  isRemote        Boolean   @default(false)
  skills          String?   // comma-separated required skills
  benefits        String?
  openings        Int       @default(1)
  status          JobStatus @default(DRAFT)
  aiMatchScore    Boolean   @default(false)
  postedDate      DateTime  @default(now())
  closingDate     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  corporate    CorporateProfile  @relation(fields: [corporateId], references: [id], onDelete: Cascade)
  applications Application[]
  savedJobs    SavedJob[]
}

// ─── Resume ──────────────────────────────────────────────────────

model Resume {
  id              String   @id @default(cuid())
  userId          String
  title           String
  summary         String?
  experience      String?  // JSON string of experience entries
  education       String?  // JSON string of education entries
  skills          String?  // JSON string of skill entries
  certifications  String?  // JSON string
  projects        String?  // JSON string
  languages       String?  // JSON string
  achievements    String?  // JSON string
  template        String   @default("professional")
  isDefault       Boolean  @default(false)
  aiGenerated     Boolean  @default(false)
  lastAiUpdate    DateTime?
  pdfUrl          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]
}

// ─── Applications ──────────────────────────────────────────────

enum ApplicationStatus {
  APPLIED
  SCREENING
  SHORTLISTED
  INTERVIEW_SCHEDULED
  INTERVIEWED
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN
}

model Application {
  id          String           @id @default(cuid())
  jobId       String
  userId      String
  resumeId    String?
  coverLetter String?
  status      ApplicationStatus @default(APPLIED)
  aiMatchScore Float?
  aiFeedback  String?
  appliedDate DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume? @relation(fields: [resumeId], references: [id], onDelete: SetNull)
}

// ─── Interviews ──────────────────────────────────────────────

enum InterviewType {
  PHONE
  VIDEO
  IN_PERSON
  AI_MOCK
  TECHNICAL
  HR
}

model Interview {
  id            String        @id @default(cuid())
  applicationId String?
  userId        String
  interviewerId String?
  type          InterviewType @default(VIDEO)
  scheduledAt   DateTime
  duration      Int           @default(60) // minutes
  status        String        @default("scheduled") // scheduled, completed, cancelled
  meetingLink   String?
  feedback      String?
  rating        Float?
  aiTranscript  String?
  aiFeedback    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── AI Mock Interview ──────────────────────────────────────

model AiInterviewSession {
  id              String   @id @default(cuid())
  userId          String
  jobRole         String
  industry        String?
  difficulty      String   @default("intermediate") // beginner, intermediate, advanced
  questions       String?  // JSON array of questions
  responses       String?  // JSON array of responses
  scores          String?  // JSON object with category scores
  overallScore    Float?
  communicationScore Float?
  technicalScore  Float?
  confidenceScore Float?
  problemSolvingScore Float?
  leadershipScore Float?
  cultureFitScore Float?
  transcript      String?  // JSON array of Q&A pairs
  strengths       String?  // JSON array of strength strings
  improvements    String?  // JSON array of improvement area strings
  recommendation  String?  // Hire, No-Hire, Strong Hire
  aiFeedback      String?
  duration        Int?     // actual duration in seconds
  status          String   @default("created") // created, in_progress, completed, abandoned
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Training & Skills ──────────────────────────────────────

model TrainingCourse {
  id            String   @id @default(cuid())
  title         String
  description   String
  category      String   // Programming, Data Science, Design, Marketing, etc.
  level         String   @default("beginner") // beginner, intermediate, advanced
  duration      Int      // in hours
  skills        String?  // comma-separated skills that will be learned
  instructor    String?
  thumbnailUrl  String?
  videoUrl      String?
  isAiGenerated Boolean  @default(false)
  rating        Float    @default(0)
  enrollCount   Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  enrollments TrainingEnrollment[]
}

model TrainingEnrollment {
  id          String   @id @default(cuid())
  userId      String
  courseId    String
  progress    Float    @default(0) // 0-100 percentage
  status      String   @default("enrolled") // enrolled, in_progress, completed, dropped
  score       Float?
  certificate String?
  skillsAcquired String? // JSON array of new skills acquired
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  course  TrainingCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// ─── Skill Assessment ──────────────────────────────────────

model SkillAssessment {
  id          String   @id @default(cuid())
  userId      String
  skillName   String
  level       Float    @default(0) // 0-100
  source      String   @default("self") // self, training, ai_assessment, interview
  evidence    String?  // JSON - supporting data
  assessedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Analytics ──────────────────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String
  eventType String   // page_view, job_applied, interview_completed, training_completed, etc.
  category  String?
  metadata  String?  // JSON string with additional data
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Notifications ──────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info") // info, success, warning, error
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Saved Jobs ──────────────────────────────────────────────

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

// ─── AI Agents ──────────────────────────────────────────────

enum AgentType {
  CANDIDATE_BUDDY
  ADMIN_OUTREACH_COMPANY
  ADMIN_OUTREACH_CANDIDATE
  ADMIN_OUTREACH_HR
}

enum AgentStatus {
  ACTIVE
  PAUSED
  STOPPED
  ERROR
}

model AIAgent {
  id          String      @id @default(cuid())
  name        String
  type        AgentType
  status      AgentStatus @default(ACTIVE)
  description String?
  strategy    String?     // JSON: agent's strategy config (target criteria, email templates, schedule, etc.)
  
  // Configuration
  dailyLimit     Int     @default(50)
  dailySent      Int     @default(0)
  dailyResetAt   DateTime @default(now())
  
  // Stats
  totalTasks     Int     @default(0)
  totalSuccess   Int     @default(0)
  totalFailed    Int     @default(0)
  totalEmailsSent Int    @default(0)
  totalResponses Int     @default(0)
  totalConversions Int   @default(0)  // onboarded / interview scheduled
  avgResponseRate Float  @default(0)
  
  // Owner
  createdBy   String   // admin user id
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  tasks      AIAgentTask[]
  emails     AIAgentEmail[]
  stats      AIAgentDailyStat[]
}

enum TaskStatus {
  PENDING
  APPROVED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model AIAgentTask {
  id        String     @id @default(cuid())
  agentId   String
  type      String     // scrape_company, send_email, search_jobs, apply_job, follow_up
  status    TaskStatus @default(PENDING)
  priority  Int        @default(5)  // 1-10
  
  // Target info
  targetEmail   String?
  targetName    String?
  targetCompany String?
  targetUrl     String?  // careers page URL, job listing URL, etc.
  targetData    String?  // JSON: additional scraped data
  
  // Execution
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  result      String?   // JSON: task result data
  error       String?
  retryCount  Int       @default(0)
  maxRetries  Int       @default(3)
  
  // Admin approval
  requiresApproval Boolean @default(false)
  approvedBy       String?
  approvedAt       DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  agent AIAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

enum EmailStatus {
  DRAFT
  QUEUED
  SENT
  DELIVERED
  OPENED
  REPLIED
  BOUNCED
  FAILED
}

model AIAgentEmail {
  id        String      @id @default(cuid())
  agentId   String
  taskId    String?
  
  // Recipient
  toEmail   String
  toName    String?
  company   String?
  
  // Content
  subject   String
  body      String      // HTML email body
  templateId String?    // reference to email template used
  templateData String?  // JSON: variables used in template
  
  // Tracking
  status    EmailStatus @default(DRAFT)
  sentAt    DateTime?
  deliveredAt DateTime?
  openedAt  DateTime?
  repliedAt DateTime?
  openCount Int         @default(0)
  replyCount Int        @default(0)
  bouncedReason String?
  
  // Follow-up
  followUpSequence Int   @default(0)  // 0=initial, 1=first follow-up, 2=second, etc.
  nextFollowUpAt   DateTime?
  parentEmailId    String?  // self-reference for follow-up chain
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  agent AIAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model AIAgentDailyStat {
  id          String   @id @default(cuid())
  agentId     String
  date        DateTime // the day this stat covers
  
  // Activity
  tasksCreated   Int   @default(0)
  tasksCompleted Int   @default(0)
  tasksFailed    Int   @default(0)
  emailsSent     Int   @default(0)
  emailsDelivered Int  @default(0)
  emailsOpened   Int   @default(0)
  emailsReplied  Int   @default(0)
  emailsBounced  Int   @default(0)
  
  // Outcomes
  companiesScraped Int  @default(0)
  contactsFound    Int  @default(0)
  jobsApplied      Int  @default(0)
  interviewsScheduled Int @default(0)
  onboardingsStarted Int @default(0)
  onboardingsCompleted Int @default(0)
  
  // Derived metrics
  deliveryRate   Float  @default(0)
  openRate       Float  @default(0)
  replyRate      Float  @default(0)
  bounceRate     Float  @default(0)
  conversionRate Float  @default(0)
  
  createdAt DateTime @default(now())
  
  agent AIAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  @@unique([agentId, date])
}

model AIEmailTemplate {
  id          String   @id @default(cuid())
  name        String
  agentType   AgentType
  subject     String
  body        String   // HTML with {{variables}}
  category    String?  // introduction, follow_up, reminder, etc.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AICompanyScrape {
  id            String   @id @default(cuid())
  companyUrl    String
  companyName   String?
  careersPageUrl String?
  contactEmail  String?
  hrEmail       String?
  linkedInUrl   String?
  industry      String?
  companySize   String?
  location      String?
  scrapeData    String?  // JSON: full scraped data
  status        String   @default("pending") // pending, scraped, contacted, responded, onboarded
  lastScrapedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
