# ─── DEMO Environment (SQLite) ────────────────────────────────────
# For demo deployment (3boxesjobportal.vercel.app)
# Data is ephemeral on Vercel and auto-seeds on each cold start.

DATABASE_URL=file:./db/custom.db
DATABASE_PROVIDER=sqlite

# Authentication
NEXTAUTH_SECRET=your-secret-key-here-change-in-production
NEXTAUTH_URL=http://localhost:3000

# Application
NEXT_PUBLIC_APP_NAME=3 Boxes Jobs
NEXT_PUBLIC_APP_URL=http:localhost:3000
NEXT_PUBLIC_APP_ENV=demo

# ─── PRODUCTION Environment (Neon PostgreSQL) ───────────────────────
# For production deployment (3boxesjobs.com)
# Set these in the Vercel Dashboard for the PRODUCTION project only.
# Do NOT put Neon credentials in this file.

# DATABASE_URL=postgresql://neondb_owner:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# DATABASE_PROVIDER=postgresql
# NEXTAUTH_SECRET=your-production-secret-key-here
# NEXTAUTH_URL=https://3boxesjobs.com
# NEXT_PUBLIC_APP_NAME=3 Boxes Jobs
# NEXT_PUBLIC_APP_URL=https://3boxesjobs.com
# NEXT_PUBLIC_APP_ENV=production
