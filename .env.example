# Database (SQLite for local development)
DATABASE_URL=file:./db/custom.db

# For Vercel production deployment, you MUST set this environment variable in Vercel Dashboard:
# Option 1: Use a cloud database (recommended for production)
#   - PostgreSQL: postgresql://user:password@host:5432/dbname
#   - MySQL: mysql://user:password@host:3306/dbname
# Option 2: Use Turso (SQLite-compatible edge database - easiest migration)
#   - libsql://your-db-name-your-org.turso.io
#
# If using PostgreSQL/MySQL, also change the provider in prisma/schema.prisma from "sqlite" to "postgresql" or "mysql"

# Authentication
NEXTAUTH_SECRET=your-secret-key-here-change-in-production
NEXTAUTH_URL=http://localhost:3000

# Application
NEXT_PUBLIC_APP_NAME=3 Boxes Jobs
NEXT_PUBLIC_APP_URL=http://localhost:3000
